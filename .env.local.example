# Firebase 服務帳號金鑰（從 Firebase Console > 專案設定 > 服務帳號 > 產生新的私密金鑰 取得的 JSON）
# 複製此檔為 .env.local 並填入對應值，本機與 Vercel 環境變數設定皆使用相同三個值。

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# 私鑰需保留 \n 換行符號（從下載的 JSON 中複製 private_key 欄位整段貼上，並用雙引號包住）
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXX\n-----END PRIVATE KEY-----\n"
